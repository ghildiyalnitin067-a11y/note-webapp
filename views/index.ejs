<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    
    <div class="main w-full min-h-screen bg-zinc-900">
        
        <div class="form p-10 text-white">
            <form action="/create" method="post">
                <input
                    class="block w-full px-5 rounded-md outline-none py-2 bg-zinc-800 resize-none"
                    type="text"
                    placeholder="Title goes here" name="title"
                >

                <textarea
                    class="block w-full mt-2 rounded-md outline-none px-5 py-2 bg-zinc-800 resize-none"
                    placeholder="write your task here" name="details"
                ></textarea>

                <input
                    class="mt-2 bg-blue-600 px-5 py-2 rounded-md"
                    type="submit"
                    value="create task"
                >
            </form>
        </div>

        <div class="tasks flex gap-3 flex-wrap p-10">
            <% if(files.length >0){ %>
                <% files.forEach(function(val){ %>
                       <div class="task w-72  rounded-md w-72 px-3 py-4 bg-zinc-800">
                <h1 class="text-white text-3xl tracking-tighter">
                    <%= val %>
                </h1>
                <div class="flex w-full justify-between items-center mt-3">
                  <a href = "/file/<%= val %>" class="text-blue-500 inline-block " href="">
                    Read More.
                </a>
                <a href = "/edit/<%= val %>" class="text-zinc-600 " href="">
                    edit filename
                </a>

                </div>
                
            </div>
                    <% })  %>
                   <%} else{ %>
                <h3 class="text-zinc-600">no tasks yet.</h3>
            <% } %> 
                
           
        
             
        </div>

    </div>

</body>
</html>